# ReceiptBI API 配置示例
# 复制此文件为 .env 并填写实际值

# ===== 应用配置 =====
APP_NAME=ReceiptBI
DEBUG=false
# development, staging, production
ENVIRONMENT=development

# ===== 服务器配置 =====
HOST=0.0.0.0
PORT=8000

# ===== 数据库配置 =====
# PostgreSQL 连接字符串
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/receiptbi
# 可视化整理当前会完整读取文件；超过上限时请先拆分数据（单位：字节）
VISUAL_CLEANING_MAX_SOURCE_BYTES=268435456
VISUAL_CLEANING_MAX_XLSX_EXPANDED_BYTES=536870912

# ===== Redis 配置 (可选) =====
# REDIS_URL=redis://localhost:6379/0



# ===== 加密配置 =====
# Fernet 密钥，用于加密敏感数据
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# ===== CORS 配置 =====
CORS_ORIGINS_STR=http://localhost:3000,http://127.0.0.1:3000

# ===== LLM 配置 =====
DEFAULT_MODEL=gpt-4o
# OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=

# ===== 速率限制 =====
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ===== 日志配置 =====
LOG_LEVEL=INFO
# console, json
LOG_FORMAT=console
